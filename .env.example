# ─── SAM.gov API ─────────────────────────────────────────────────────────────
# Get your free API key at: https://sam.gov/profile/details
# Click "Edit Profile" → scroll to "API Key" → Generate Key
# NEVER expose this in the frontend — it only lives server-side
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/samhunt
# Supabase: postgresql://postgres:[password]@[host]:5432/postgres
# Neon: postgresql://[user]:[password]@[host]/samhunt?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/samhunt

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here_generate_with_openssl

# Your app's URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth Providers (optional — comment out if not using) ───────────────────
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub: https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Email (Magic Links) ──────────────────────────────────────────────────────
# Resend: https://resend.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ─── AI (optional — AI features disabled if not set) ─────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# ─── Redis (optional — falls back to in-memory cache) ────────────────────────
# Upstash: https://upstash.com
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
