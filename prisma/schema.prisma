// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       BusinessProfile?
  savedSearches SavedSearch[]
  favorites     FavoriteOpportunity[]
  searchHistory SearchHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business Profile ────────────────────────────────────────────────────────

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String?
  uei             String?  // Unique Entity Identifier (SAM.gov)
  cageCode        String?
  description     String?  @db.Text

  // NAICS codes this business operates under
  naicsCodes      String[] // e.g. ["541511", "541512"]

  // Small business certifications
  certifications  String[] // e.g. ["8a", "wosb", "sdvosb", "hubzone", "vosb", "sdb"]

  // Geographic preferences
  preferredStates String[] // e.g. ["IN", "OH", "IL"]
  homeZip         String?

  // Target agencies
  targetAgencies  String[] // e.g. ["DOD", "DHS", "VA"]

  // Contract size preferences (in dollars)
  minContractSize Int?
  maxContractSize Int?

  // Other preferences
  allowRemote     Boolean  @default(true)
  preferredNoticeTypes String[] // e.g. ["Solicitation", "Sources Sought"]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Saved Searches ──────────────────────────────────────────────────────────

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  name        String
  query       Json     // Stores the full SearchParams object
  notifyEmail Boolean  @default(false)
  lastRunAt   DateTime?
  resultCount Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model FavoriteOpportunity {
  id              String   @id @default(cuid())
  userId          String
  noticeId        String   // SAM.gov noticeId
  solicitationNumber String?
  title           String
  agencyName      String?
  noticeType      String?
  postedDate      DateTime?
  responseDeadLine DateTime?
  naicsCode       String?
  setAside        String?
  placeOfPerformance String?
  samUrl          String
  notes           String?  @db.Text
  fitScore        Int?     // 0-100
  aiSummary       String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, noticeId])
}

// ─── Search History ──────────────────────────────────────────────────────────

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  query       Json
  resultCount Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ─── Cache (for popular searches) ───────────────────────────────────────────

model SearchCache {
  id          String   @id @default(cuid())
  cacheKey    String   @unique
  data        Json
  hitCount    Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}
